<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.shopapp">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Shopify"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Shopify">

        <!-- MainActivity uses NoActionBar (has its own custom top bar) -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Shopify" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- All other screens use the ActionBar theme (for the back arrow) -->
        <activity android:name=".activities.ProductDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Shopify.ActionBar"
            android:parentActivityName=".activities.MainActivity" />

        <activity android:name=".activities.CartActivity"
            android:exported="false"
            android:theme="@style/Theme.Shopify.ActionBar"
            android:parentActivityName=".activities.MainActivity" />

        <activity android:name=".activities.CheckoutActivity"
            android:exported="false"
            android:theme="@style/Theme.Shopify.ActionBar"
            android:parentActivityName=".activities.CartActivity" />

        <activity android:name=".activities.OrderHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.Shopify.ActionBar"
            android:parentActivityName=".activities.MainActivity" />

        <activity android:name=".activities.WishlistActivity"
            android:exported="false"
            android:theme="@style/Theme.Shopify.ActionBar"
            android:parentActivityName=".activities.MainActivity" />

    </application>
</manifest>
