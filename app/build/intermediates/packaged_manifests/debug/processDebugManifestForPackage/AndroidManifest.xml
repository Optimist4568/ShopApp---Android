<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.shopapp"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="35" />

    <permission
        android:name="com.example.shopapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.shopapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Shopify"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.Shopify" >

        <!-- MainActivity uses NoActionBar (has its own custom top bar) -->
        <activity
            android:name="com.example.shopapp.activities.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Shopify" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- All other screens use the ActionBar theme (for the back arrow) -->
        <activity
            android:name="com.example.shopapp.activities.ProductDetailActivity"
            android:exported="false"
            android:parentActivityName="com.example.shopapp.activities.MainActivity"
            android:theme="@style/Theme.Shopify.ActionBar" />
        <activity
            android:name="com.example.shopapp.activities.CartActivity"
            android:exported="false"
            android:parentActivityName="com.example.shopapp.activities.MainActivity"
            android:theme="@style/Theme.Shopify.ActionBar" />
        <activity
            android:name="com.example.shopapp.activities.CheckoutActivity"
            android:exported="false"
            android:parentActivityName="com.example.shopapp.activities.CartActivity"
            android:theme="@style/Theme.Shopify.ActionBar" />
        <activity
            android:name="com.example.shopapp.activities.OrderHistoryActivity"
            android:exported="false"
            android:parentActivityName="com.example.shopapp.activities.MainActivity"
            android:theme="@style/Theme.Shopify.ActionBar" />
        <activity
            android:name="com.example.shopapp.activities.WishlistActivity"
            android:exported="false"
            android:parentActivityName="com.example.shopapp.activities.MainActivity"
            android:theme="@style/Theme.Shopify.ActionBar" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.example.shopapp.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>